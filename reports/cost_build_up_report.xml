<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Cost Build-Up Report HTML Version -->
    <record id="action_cost_build_up_report" model="ir.actions.report">
        <field name="name">Cost Build Up Report</field>
        <field name="model">foreign.shipment</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">foreign_purchase_module.report_cost_build_up</field>
        <field name="report_file">foreign_purchase_module.report_cost_build_up</field>
