<odoo>
    <record id="view_foreign_lc_cad_tree" model="ir.ui.view">
        <field name="name">foreign.lc_cad.list</field>
        <field name="model">foreign.lc_cad</field>
        <field name="arch" type="xml">
            <list string="LC/CAD" decoration-info="state == 'draft'" decoration-success="state == 'open'" decoration-muted="state in ('closed', 'archived')">
                <field name="name"/>
                <field name="instrument_type"/>
                <field name="purchase_order_id"/>
                <field name="issuing_bank"/>
                <field name="expiry_date"/>
                <field name="total_value" widget="monetary"/>
                <field name="total_costs" widget="monetary"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'open'"/>
            </list>
        </field>
    </record>

    <record id="view_foreign_lc_cad_form" model="ir.ui.view">
        <field name="name">foreign.lc_cad.form</field>
        <field name="model">foreign.lc_cad</field>
        <field name="arch" type="xml">
            <form string="LC/CAD">
                <header>
                    <button name="action_open" string="Open" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_create_shipment" string="Create Shipment" type="object" class="oe_highlight" invisible="state != 'open' or not has_remaining_qty"/>
                    <button name="action_close_lc" string="Close LC" type="object" class="oe_highlight" invisible="not can_close_lc"/>
                    <button name="action_archive" string="Archive" type="object" invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,open,closed,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="LC/CAD Number" readonly="state != 'draft'"/>
                        </h1>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_shipments" type="object" class="oe_stat_button" icon="fa-truck" groups="base.group_user" 
                                invisible="shipment_count == 0">
                            <field name="shipment_count" widget="statinfo" string="Shipments"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="instrument_type" readonly="state != 'draft'"/>
                            <field name="purchase_order_id" readonly="state != 'draft'"/>
                            <field name="issuing_bank" readonly="state != 'draft'"/>
                            <field name="beneficiary" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="issuance_date" readonly="state != 'draft'"/>
                            <field name="expiry_date" readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="total_value" widget="monetary" readonly="state != 'draft'"/>
                            <field name="no_further_shipments"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Costs" name="costs">
                            <field name="cost_line_ids">
                                <list editable="bottom">
                                    <field name="cost_type_id"/>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="bill_state" widget="badge" decoration-info="bill_state == 'draft'" decoration-success="bill_state == 'posted'" invisible="not vendor_bill_id"/>
                                    <button name="create_bill" string="Create Bill" type="object" icon="fa-pencil-square-o" invisible="vendor_bill_id or is_adjustment"/>
                                    <button name="view_bill" string="View Bill" type="object" icon="fa-eye" invisible="not vendor_bill_id or is_adjustment"/>
                                    <button name="create_journal" string="Create Journal" type="object" icon="fa-pencil-square-o" invisible="vendor_bill_id or not is_adjustment"/>
                                    <button name="action_view_journal" string="View Journal" type="object" icon="fa-book" invisible="not vendor_bill_id or not is_adjustment"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_costs" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Product Lines" name="product_lines">
                            <field name="product_line_ids">
                                <list string="Product Lines" editable="bottom">
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="product_qty"/>
                                    <field name="product_uom"/>
                                    <field name="price_unit"/>
                                </list>
                            </field>
                        </page>
                        <page string="Status Info" name="status_info">
                            <group>
                                <field name="all_bills_paid" readonly="1"/>
                                <field name="all_shipments_completed" readonly="1"/>
                                <field name="can_be_closed" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_foreign_lc_cad_search" model="ir.ui.view">
        <field name="name">foreign.lc_cad.search</field>
        <field name="model">foreign.lc_cad</field>
        <field name="arch" type="xml">
            <search string="Search LC/CAD">
                <field name="name"/>
                <field name="issuing_bank"/>
                <field name="purchase_order_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Open" name="open" domain="[('state', '=', 'open')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" context="{'group_by': 'state'}"/>
                    <filter string="Instrument Type" name="instrument_type" context="{'group_by': 'instrument_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_foreign_lc_cad" model="ir.actions.act_window">
        <field name="name">LC/CAD Management</field>
        <field name="res_model">foreign.lc_cad</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first LC/CAD!
            </p>
        </field>
    </record>
</odoo>
