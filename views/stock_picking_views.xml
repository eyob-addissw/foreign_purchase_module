<odoo>
    <!-- Inherit stock picking form view to add unit price and cost price to operations -->
    <record id="view_picking_form_inherit_foreign" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.foreign</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <!-- Embedded Operations tab: move_ids_without_package is a stock.move one2many.
                 In list views, hide/show must be done with column_invisible, and the picking is available as `parent`. -->
            <xpath expr="//page[@name='operations']//field[@name='move_ids_without_package']//list//field[@name='product_uom']" position="after">
                <field name="price_unit" string="Unit Price" readonly="1" optional="show"
                       column_invisible="parent.picking_type_code != 'incoming'"/>
                <field name="inventory_cost" string="Cost Price" readonly="1" optional="show"
                       column_invisible="parent.picking_type_code != 'incoming'"/>
            </xpath>
        </field>
    </record>
</odoo>
