<odoo>
    <record id="view_foreign_lc_cad_cost_type_tree" model="ir.ui.view">
        <field name="name">foreign.lc_cad.cost_type.list</field>
        <field name="model">foreign.lc_cad.cost_type</field>
        <field name="arch" type="xml">
            <list string="Cost Types">
                <field name="name"/>
                <field name="description"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_foreign_lc_cad_cost_type_form" model="ir.ui.view">
        <field name="name">foreign.lc_cad.cost_type.form</field>
        <field name="model">foreign.lc_cad.cost_type</field>
        <field name="arch" type="xml">
            <form string="Cost Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="is_tax"/>
                        <field name="is_adjustment"/>
                        <field name="git_account_id" invisible="not is_adjustment" required="is_adjustment"/>
                        <field name="tax_account_id" invisible="not is_tax" required="is_tax"/>
                        <field name="adjustment_account_id" invisible="not is_adjustment" required="is_adjustment"/>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_foreign_lc_cad_cost_type_search" model="ir.ui.view">
        <field name="name">foreign.lc_cad.cost_type.search</field>
        <field name="model">foreign.lc_cad.cost_type</field>
        <field name="arch" type="xml">
            <search string="Search Cost Types">
                <field name="name"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactive" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="action_foreign_lc_cad_cost_type" model="ir.actions.act_window">
        <field name="name">Cost Types</field>
        <field name="res_model">foreign.lc_cad.cost_type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first cost type!
            </p>
        </field>
    </record>
</odoo>
