<odoo>
    <record id="view_company_form_inherit_foreign_purchase_git" model="ir.ui.view">
        <field name="name">res.company.form.inherit.foreign.purchase.git</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//group" position="inside">
                <group string="Foreign Purchase">
                    <field name="foreign_purchase_git_account_id"
                           options="{'no_create': True}"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>

