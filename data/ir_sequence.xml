<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- LC/CAD Number Sequence -->
        <record id="sequence_foreign_lc_cad" model="ir.sequence">
            <field name="name">LC/CAD Number</field>
            <field name="code">foreign.lc_cad</field>
            <field name="prefix">LC/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="implementation">standard</field>
        </record>
        
        <!-- Shipment Number Sequence -->
        <record id="sequence_foreign_shipment" model="ir.sequence">
            <field name="name">Shipment Number</field>
            <field name="code">foreign.shipment</field>
            <field name="prefix">SHIP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="implementation">standard</field>
        </record>
    </data>
</odoo>
